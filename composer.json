{
    "name": "teacherli07/flarum-anonymous",
    "description": "Anonymous community extension for Flarum.",
    "type": "flarum-extension",
    "keywords": ["anonymous"],
    "license": "MIT",
    "require": {
        "flarum/core": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "TeacherLi07\\Anonymous\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "Anonymous Community",
            "category": "feature",
            "icon": {
                "name": "fas fa-user-secret",
                "backgroundColor": "#238c59",
                "color": "#fff"
            }
        }
    }
}
